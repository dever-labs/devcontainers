{
  // Definition for the dotnet-service devcontainer image.
  // This file is used by CI to build and push the image to GHCR.
  // Service repos reference the resulting image — they do not build it themselves.
  "name": "dotnet-dev",
  "build": { "dockerfile": "Dockerfile" },

  "features": {
    // .NET SDK — pin to major.minor so patch updates flow automatically
    "ghcr.io/devcontainers/features/dotnet:2": {
      "version": "10.0"
    },
    // Docker-in-Docker — required for kind cluster nodes inside the container
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "version": "latest"
    },
    // kubectl + Helm + minikube — local cluster for developing against team helm charts
    "ghcr.io/devcontainers/features/kubectl-helm-minikube:1": {
      "version": "latest",
      "helm": "latest",
      "minikube": "latest"
    },
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {},
    // Node.js — required for Claude Code CLI
    "ghcr.io/devcontainers/features/node:1": {
      "version": "lts",
      "nodeGypDependencies": false
    }
  },

  "postCreateCommand": "npm install -g @github/copilot @anthropic-ai/claude-code && sudo ln -sf $(npm prefix -g)/bin/copilot /usr/local/bin/copilot && sudo ln -sf $(npm prefix -g)/bin/claude /usr/local/bin/claude",

  "postStartCommand": "[ \"$(uname -m)\" = \"aarch64\" ] || (minikube status || minikube start --driver=docker)",

  "mounts": [
    // Persist gh credentials across all dever-labs devcontainers.
    // Run `gh auth login` once — every container that mounts this volume gets your credentials.
    "source=dever-labs-gh-config,target=/home/vscode/.config/gh,type=volume",
    // Persist Copilot CLI credentials (stored at ~/.copilot/config.json on headless Linux).
    // Run `copilot /login` once — all containers with this volume stay authenticated.
    "source=dever-labs-copilot,target=/home/vscode/.copilot,type=volume"
  ],

  "remoteEnv": {
    // Forward host GitHub token so AI agents and CLI tools can authenticate without re-login
    "PATH": "/usr/local/bin:${containerEnv:PATH}",
    "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}"
  },

  "customizations": {
    "vscode": {
      "extensions": [
        // AI agents
        "github.copilot",
        "github.copilot-chat",
        "anthropics.claude-code",
        // .NET
        "ms-dotnettools.csdevkit",
        "ms-dotnettools.csharp",
        "ms-dotnettools.vscode-dotnet-runtime",
        // REST API testing
        "humao.rest-client",
        // Code quality
        "editorconfig.editorconfig"
      ]
    }
  }
}
