{
  // Definition for the infra devcontainer image.
  // This file is used by CI to build and push the image to GHCR.
  // Service repos reference the resulting image -- they do not build it themselves.
  "name": "infra-dev",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu-24.04",

  "features": {
    // Terraform -- IaC for cloud infrastructure
    "ghcr.io/devcontainers/features/terraform:1": {
      "version": "latest"
    },
    // Azure CLI -- primary cloud provider
    "ghcr.io/devcontainers/features/azure-cli:1": {
      "version": "latest"
    },
    // Docker-in-Docker -- required for kind cluster nodes inside the container
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "version": "latest"
    },
    // kubectl + Helm -- cluster management and chart deployments
    "ghcr.io/devcontainers/features/kubectl-helm-minikube:1": {
      "version": "latest",
      "helm": "latest",
      "minikube": "latest"
    },
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {},
    // Node.js — required for Claude Code CLI
    "ghcr.io/devcontainers/features/node:1": {
      "version": "lts",
      "nodeGypDependencies": false
    }
  },

  // AWS CLI, GCP SDK and ArgoCD CLI installed via shell — devcontainers-contrib features
  // are unreliable in CI (access/permissions issues).
  "onCreateCommand": "curl -fsSL https://install.openclaw.ai | sh && npm install -g @anthropic-ai/claude-code && curl -fsSL https://awscli.amazonaws.com/awscli-exe-linux-x86_64.zip -o /tmp/awscliv2.zip && unzip -q /tmp/awscliv2.zip -d /tmp && sudo /tmp/aws/install && rm -rf /tmp/awscliv2.zip /tmp/aws && curl -fsSL https://sdk.cloud.google.com | bash -s -- --disable-prompts --install-dir=/usr/local/gcloud && ln -sf /usr/local/gcloud/google-cloud-sdk/bin/gcloud /usr/local/bin/gcloud && curl -sSL -o /usr/local/bin/argocd https://github.com/argoproj/argo-cd/releases/latest/download/argocd-linux-amd64 && chmod +x /usr/local/bin/argocd",

  "postStartCommand": "[ \"$(uname -m)\" = \"aarch64\" ] || (minikube status || minikube start --driver=docker)",

  "mounts": [
    // Persist gh credentials across all dever-labs devcontainers.
    // Run `gh auth login` once — every container that mounts this volume gets your credentials.
    "source=dever-labs-gh-config,target=/home/vscode/.config/gh,type=volume"
  ],

  "remoteEnv": {
    "GITHUB_TOKEN": "${localEnv:GITHUB_TOKEN}"
  },

  "customizations": {
    "vscode": {
      "extensions": [
        // AI agents
        "github.copilot",
        "github.copilot-chat",
        "anthropics.claude-code",
        // Infrastructure
        "hashicorp.terraform",
        "ms-kubernetes-tools.vscode-kubernetes-tools",
        "ms-azuretools.vscode-azureterraform",
        "redhat.vscode-yaml"
      ]
    }
  }
}
