{
  // Definition for the infra devcontainer image.
  // This file is used by CI to build and push the image to GHCR.
  // Service repos reference the resulting image -- they do not build it themselves.
  "name": "infra-dev",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu-24.04",

  "features": {
    // Terraform -- IaC for cloud infrastructure
    "ghcr.io/devcontainers/features/terraform:1": {
      "version": "latest"
    },
    // Azure CLI -- primary cloud provider
    "ghcr.io/devcontainers/features/azure-cli:1": {
      "version": "latest"
    },
    // Docker-in-Docker -- required for kind cluster nodes inside the container
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "version": "latest"
    },
    // kubectl + Helm -- cluster management and chart deployments
    "ghcr.io/devcontainers/features/kubectl-helm-minikube:1": {
      "version": "latest",
      "helm": "latest",
      "minikube": "latest"
    },
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/github-cli:1": {}
  },

  // AWS CLI, GCP SDK and ArgoCD CLI installed via shell — devcontainers-contrib features
  // are unreliable in CI (access/permissions issues).
  "onCreateCommand": "curl -fsSL https://install.openclaw.ai | sh && curl -fsSL https://awscli.amazonaws.com/awscli-exe-linux-x86_64.zip -o /tmp/awscliv2.zip && unzip -q /tmp/awscliv2.zip -d /tmp && sudo /tmp/aws/install && rm -rf /tmp/awscliv2.zip /tmp/aws && curl -fsSL https://sdk.cloud.google.com | bash -s -- --disable-prompts --install-dir=/usr/local/gcloud && ln -sf /usr/local/gcloud/google-cloud-sdk/bin/gcloud /usr/local/bin/gcloud && curl -sSL -o /usr/local/bin/argocd https://github.com/argoproj/argo-cd/releases/latest/download/argocd-linux-amd64 && chmod +x /usr/local/bin/argocd",

  "postStartCommand": "minikube status || minikube start --driver=docker",

  "customizations": {
    "vscode": {
      "extensions": [
        "github.copilot",
        "github.copilot-chat",
        "ms-kubernetes-tools.vscode-kubernetes-tools",
        "hashicorp.terraform"
      ]
    }
  }
}